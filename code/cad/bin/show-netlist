#!/usr/bin/env bash
# Print every routed net + the pins it reaches. Quick human eyeball of the
# bus → sensor harness without opening SCAD.
set -euo pipefail
cd "$(dirname "$0")/.."
exec uv run python -c '
import sys
sys.path.insert(0, "src")
from collections import deque
from netlist import NETS, PRIMARY_BUS
from vitamins.substrate import (
    Via, WireSegment, _build_paths_for_net, _pin_position,
)

def key(pt): return (round(pt.x, 4), round(pt.y, 4))

print(f"Bus: {PRIMARY_BUS.name}   master={PRIMARY_BUS.master}   "
      f"devices={list(PRIMARY_BUS.devices)}")
print()

for sig, net in NETS.items():
    paths = _build_paths_for_net(net)
    elements = [e for p in paths for e in p.elements]
    # Build adjacency
    g = {}
    for el in elements:
        if isinstance(el, WireSegment):
            g.setdefault(key(el.start), set()).add(key(el.end))
            g.setdefault(key(el.end),   set()).add(key(el.start))
        elif isinstance(el, Via):
            g.setdefault(key(el.position), set())
    # BFS from master
    start = key(_pin_position(net.master_pin))
    reached = {start}
    q = deque([start])
    while q:
        n = q.popleft()
        for m in g.get(n, ()):
            if m not in reached:
                reached.add(m); q.append(m)

    print(f"{sig.name:4} (KiCad {sig.value!r}):")
    mp = net.master_pin
    mp_pos = _pin_position(mp)
    print(f"  master  {mp.ref}.{mp.number:<2}  ({mp_pos.x:>7.2f}, {mp_pos.y:>7.2f})")
    for dp in net.device_pins:
        pos = _pin_position(dp)
        ok = "reachable" if key(pos) in reached else "UNREACHABLE"
        print(f"  device  {dp.ref}.{dp.number:<2}  ({pos.x:>7.2f}, {pos.y:>7.2f})  {ok}")
    n_segs = sum(1 for e in elements if isinstance(e, WireSegment))
    n_vias = sum(1 for e in elements if isinstance(e, Via))
    length = sum(p.length_mm() for p in paths)
    print(f"  layout  L1+L2  segs={n_segs}  vias={n_vias}  "
          f"corridor_y={net.corridor_y}  north_x={net.north_x}")
    print(f"  wire    {length:6.2f} mm (Manhattan segs + via vertical traversal)")
    print()
'
