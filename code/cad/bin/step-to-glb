#!/usr/bin/env bash
# step-to-glb — convert STEP / STP to GLB.
#
# Two stages:
#   STEP -> STL  (FreeCADCmd + freecad/step_to_stl.py)
#   STL  -> GLB  (bin/_stl-to-glb, trimesh)
#
# Inputs to the FreeCAD stage travel via env vars (STEP_IN / STL_OUT /
# DEFLECTION). CRITICAL: LD_LIBRARY_PATH / PYTHONPATH / VIRTUAL_ENV
# from the cad devshell crash FreeCAD's bundled libstdc++ at startup,
# so the FreeCADCmd invocation runs in a subshell that strips them.
#
# Usage: step-to-glb INPUT.step OUTPUT.glb [--deflection MM]

set -euo pipefail

deflection="0.1"
input=""
output=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --deflection) deflection="$2"; shift 2;;
    -h|--help)
      sed -n '2,14p' "$0" | sed 's/^# \?//'; exit 0;;
    *)
      if [[ -z "$input" ]]; then input="$1"
      elif [[ -z "$output" ]]; then output="$1"
      else echo "step-to-glb: unexpected arg: $1" >&2; exit 2
      fi
      shift;;
  esac
done

if [[ -z "$input" || -z "$output" ]]; then
  echo "usage: step-to-glb INPUT.step OUTPUT.glb [--deflection MM]" >&2
  exit 2
fi

if [[ ! -f "$input" ]]; then
  echo "step-to-glb: input not found: $input" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
freecad_script="${script_dir}/../freecad/step_to_stl.py"
mkdir -p "$(dirname "$output")"

stl="$(mktemp -t step-to-glb.XXXXXX.stl)"
trap 'rm -f "$stl"' EXIT

(
  unset LD_LIBRARY_PATH PYTHONPATH VIRTUAL_ENV PYTHONHASHSEED \
        PYTHONNOUSERSITE _PYTHON_HOST_PLATFORM \
        _PYTHON_SYSCONFIGDATA_NAME VIRTUAL_ENV_PROMPT
  STEP_IN="$input" STL_OUT="$stl" DEFLECTION="$deflection" \
    FreeCADCmd "$freecad_script"
) >/dev/null

if [[ ! -s "$stl" ]]; then
  echo "step-to-glb: FreeCADCmd produced no STL for $input" >&2
  exit 1
fi

"${script_dir}/_stl-to-glb" "$stl" "$output"

bytes="$(stat -c %s "$output")"
echo "step-to-glb: wrote $output (${bytes} bytes)"
