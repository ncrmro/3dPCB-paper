#!/usr/bin/env bash
# Compare routed boards by scoring their signal paths. Lower aggregate
# is better. Score components + weights live in router/score.py.
#
# Usage:
#   score-routes              # all specs in code/cad/specs/
#   score-routes i2c_starter  # only the named spec(s)
set -euo pipefail
CAD_DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec uv --project "$CAD_DIR" run env PYTHONPATH="$CAD_DIR/src" \
    python -m board.cli_score "$@"
