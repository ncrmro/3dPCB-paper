#!/usr/bin/env bash
# Emit per-board JSON reports consumed by the gallery focus page.
#
# Writes one file per spec to code/web/src/reports/substrate_<name>.json,
# where <name> matches the GLB stem (so the .astro page can look up the
# report by manifest entry name).
#
# Each report carries the routing-score breakdown and the full drilled-
# hole inventory. Skips specs that can't be loaded or have no routable
# nets.
set -euo pipefail
CAD_DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec uv --project "$CAD_DIR" run env PYTHONPATH="$CAD_DIR/src" \
    python -m board.cli_report "$@"
