#!/usr/bin/env -S uv run python
"""Render registered AnchorSCAD parts to .scad, .stl, .3mf, and .glb.

Pipeline per part:
    factory() -> ad.Shape  -> .scad (anchorscad)
    .scad                  -> .stl  (openscad — for slicers / downloads)
    .scad                  -> .3mf  (openscad — color-aware intermediate)
    .3mf                   -> .glb  (trimesh — preserves OpenSCAD colors)

Emits build/manifest.json listing each part with relative paths to its
.scad/.stl/.3mf/.glb so downstream consumers (the Astro gallery) can
wire up cards without re-scanning the build dir.

The GLB used to be produced via `assimp export <stl> <glb>`, but STL
doesn't carry color; the resulting GLBs rendered as untextured meshes
in <model-viewer>. 3MF preserves OpenSCAD's color() calls as per-
triangle material refs, and trimesh's GLB writer encodes them as
ColorVisuals on the mesh — which model-viewer renders as expected.

Each step is best-effort — a failure in one part does not abort the
whole run, the manifest just omits the missing path.
"""

import json
import sys
import importlib
import pkgutil
import shutil
import subprocess
from pathlib import Path
from unittest.mock import MagicMock

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT / "src"))

sys.modules["OpenGL"] = MagicMock()
sys.modules["OpenGL.GL"] = MagicMock()

import anchorscad as ad  # noqa: E402
import registry  # noqa: E402
import vitamins  # noqa: E402


def _walk(package):
    for _, name, _ in pkgutil.walk_packages(list(package.__path__), package.__name__ + "."):
        yield importlib.import_module(name)


def _run(cmd: list[str]) -> bool:
    """Run cmd; return True on success, False otherwise (don't raise)."""
    try:
        subprocess.run(cmd, check=True, capture_output=True)
        return True
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        stderr = getattr(exc, "stderr", None)
        msg = stderr.decode(errors="replace") if stderr else str(exc)
        tail = msg.strip().splitlines()[-1] if msg.strip() else str(exc)
        print(f"  ! {cmd[0]} failed: {tail}", file=sys.stderr)
        return False


def _convert_3mf_to_glb(src: Path, dst: Path) -> bool:
    """Convert 3MF → GLB preserving OpenSCAD's per-color() face colors.

    trimesh's stock 3MF loader collapses every basematerial into a
    single "default" color (it doesn't honour the per-triangle pid
    refs). We parse the 3MF XML directly, duplicate vertices per
    triangle so each face owns its own corner colors, then hand the
    expanded mesh to trimesh's GLB writer — which faithfully encodes
    COLOR_0 vertex attributes that <model-viewer> renders.
    """
    try:
        import zipfile
        from xml.etree import ElementTree as ET
        import numpy as np  # type: ignore
        import trimesh  # type: ignore
    except ImportError as exc:
        print(f"  ! missing dep for 3mf→glb: {exc}", file=sys.stderr)
        return False
    try:
        with zipfile.ZipFile(src) as zf:
            xml = zf.read("3D/3dmodel.model").decode("utf-8")
        ns = {"m": "http://schemas.microsoft.com/3dmanufacturing/core/2015/02"}
        root = ET.fromstring(xml)

        colors: list[tuple[int, int, int, int]] = []
        for bm in root.findall(".//m:basematerials/m:base", ns):
            c = bm.get("displaycolor", "#888888FF").lstrip("#")
            if len(c) == 6:
                c += "FF"
            colors.append(tuple(int(c[i : i + 2], 16) for i in (0, 2, 4, 6)))  # type: ignore[arg-type]

        verts = [
            (float(v.get("x") or 0), float(v.get("y") or 0), float(v.get("z") or 0))
            for v in root.findall(".//m:mesh/m:vertices/m:vertex", ns)
        ]

        new_verts: list[tuple[float, float, float]] = []
        new_colors: list[tuple[int, int, int, int]] = []
        new_faces: list[tuple[int, int, int]] = []
        default_color = (200, 200, 200, 255)
        for tri in root.findall(".//m:mesh/m:triangles/m:triangle", ns):
            v1, v2, v3 = int(tri.get("v1") or 0), int(tri.get("v2") or 0), int(tri.get("v3") or 0)
            pid_attr = tri.get("p1")
            pid = int(pid_attr) if pid_attr is not None else 0
            color = colors[pid] if 0 <= pid < len(colors) else default_color
            base = len(new_verts)
            new_verts.extend([verts[v1], verts[v2], verts[v3]])
            new_colors.extend([color, color, color])
            new_faces.append((base, base + 1, base + 2))

        mesh = trimesh.Trimesh(
            vertices=np.array(new_verts, dtype=np.float32),
            faces=np.array(new_faces, dtype=np.int32),
            vertex_colors=np.array(new_colors, dtype=np.uint8),
            process=False,
        )
        mesh.export(str(dst))
        return True
    except Exception as exc:  # noqa: BLE001 — best-effort
        print(f"  ! 3mf→glb failed: {exc}", file=sys.stderr)
        return False


def main() -> int:
    out = REPO_ROOT / "build"
    out.mkdir(exist_ok=True)

    for mod in _walk(vitamins):
        registry.auto_register_module(mod, part_type="vitamin")

    have_openscad = shutil.which("openscad") is not None
    if not have_openscad:
        print("note: 'openscad' not on PATH — skipping STL/3MF/GLB steps", file=sys.stderr)

    manifest_models: list[dict] = []
    for name, (factory, ptype, fmt) in registry.get_registry().items():
        if fmt != "anchorscad":
            continue

        shape = factory()
        scad_path = out / f"{name}.scad"
        # AnchorSCAD's RenderResult.rendered_shape is a LazyUnion;
        # dumps() returns the SCAD source as a string. The older
        # `.code.code` chain in earlier docs/snapshots no longer exists
        # in the pinned anchorscad-core.
        scad_path.write_text(ad.render(shape).rendered_shape.dumps())
        print(f"wrote {scad_path}")

        entry: dict = {
            "name": name,
            "type": ptype,
            "scad": scad_path.relative_to(out).as_posix(),
        }

        if have_openscad:
            stl_path = out / f"{name}.stl"
            if _run(["openscad", "-o", str(stl_path), str(scad_path)]):
                print(f"wrote {stl_path}")
                entry["stl"] = stl_path.relative_to(out).as_posix()

            tmf_path = out / f"{name}.3mf"
            if _run(["openscad", "-o", str(tmf_path), str(scad_path)]):
                print(f"wrote {tmf_path}")
                entry["3mf"] = tmf_path.relative_to(out).as_posix()

                glb_path = out / f"{name}.glb"
                if _convert_3mf_to_glb(tmf_path, glb_path):
                    print(f"wrote {glb_path}")
                    entry["glb"] = glb_path.relative_to(out).as_posix()

        manifest_models.append(entry)

    manifest = {"project": "cad", "models": manifest_models}
    manifest_path = out / "manifest.json"
    manifest_path.write_text(json.dumps(manifest, indent=2) + "\n")
    print(f"wrote {manifest_path}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
