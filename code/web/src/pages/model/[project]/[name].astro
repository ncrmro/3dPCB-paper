---
export const prerender = true;

// Focus route: /model/{project}/{name}/
//
// URL-driven slot pattern — clicking a card on the index lands here.
// The page renders the focused model at the top of the layout, then
// the full gallery underneath so navigation stays one click away.
//
// `project` is "cad" or "kicad"; `name` matches the manifest entry.
// Both manifests are inlined at build time via Vite's ?raw glob.
import { parse as parseYaml } from "yaml";
import cadManifestYaml from "../../../manifest.cad.yaml?raw";
import kicadManifestYaml from "../../../manifest.kicad.yaml?raw";

// Pre-computed per-substrate reports written by
// `code/cad/bin/substrate-report` during the prebuild step. Indexed
// by the substrate's snake-case stem (same as the manifest entry
// name and the GLB stem), so the focus page can resolve a model →
// its report by file name. Spec YAMLs are inlined the same way so
// the editor textarea can render the source without a fetch.
const reportFiles = import.meta.glob<string>("../../../reports/*.json", {
  query: "?raw",
  import: "default",
  eager: true,
});
const specFiles = import.meta.glob<string>("../../../../../cad/specs/*.yaml", {
  query: "?raw",
  import: "default",
  eager: true,
});

interface HoleRow {
  name: string;
  x: number;
  y: number;
  diameter: number;
}
interface InvariantResult {
  key: string;
  label: string;
  passed: boolean;
  message: string;
}
interface ScoreBreakdown {
  total_length_mm: number;
  l1_length_mm: number;
  l2_length_mm: number;
  via_count: number;
  edge_clearance_min_mm: number;
  pedestal_underside_mm: number;
  aggregate: number;
}
interface MinSize {
  width_mm: number;
  height_mm: number;
  center_x: number;
  center_y: number;
  current_width_mm: number;
  current_height_mm: number;
  slack_width_mm: number;
  slack_height_mm: number;
}
interface SubstrateReport {
  name: string;
  class: string;
  spec_path: string | null;
  score: ScoreBreakdown;
  min_size?: MinSize;
  invariants: InvariantResult[];
  holes: HoleRow[];
}

interface CadModel {
  name: string;
  glb: string;
  camera?: string;
}
interface CadManifest {
  project: string;
  cameras?: Record<string, string>;
  models: CadModel[];
}
type KicadModel = { name: string; label?: string; camera?: string };
type KicadManifest = {
  project: string;
  models: KicadModel[];
  cameras?: Record<string, string>;
};

const cad = parseYaml(cadManifestYaml) as CadManifest;
const kicad = parseYaml(kicadManifestYaml) as KicadManifest;
const cadCameras = cad.cameras ?? {};
const kicadCameras = kicad.cameras ?? {};

export function getStaticPaths() {
  const cadM = parseYaml(cadManifestYaml) as CadManifest;
  const kicadM = parseYaml(kicadManifestYaml) as KicadManifest;
  const paths: { params: { project: string; name: string }; props: Record<string, unknown> }[] = [];
  for (const m of cadM.models) {
    paths.push({ params: { project: "cad", name: m.name }, props: { model: m, project: "cad" } });
  }
  for (const m of kicadM.models) {
    paths.push({ params: { project: "kicad", name: m.name }, props: { model: m, project: "kicad" } });
  }
  return paths;
}

interface FocusProps {
  model: CadModel | KicadModel;
  project: "cad" | "kicad";
}
const { model, project } = Astro.props as FocusProps;

// Append a build-time cache-buster to GLB URLs so model-viewer's
// internal cache can't serve a stale GLB after a re-render. The
// timestamp changes every time Astro rebuilds (dev: every HMR; prod:
// per build), which is fine for our use — the underlying file is
// behind the same /public/ URL, the query string is ignored by the
// static-asset handler but invalidates the browser-side cache key.
const BUILD_BUST = `?v=${Date.now()}`;

// Resolve the focused asset URLs + camera by project.
let focusedGlb: string;
let focusedCameraOrbit: string;
let focusedLabel: string;
let focusedImg: string | null = null;

// Optional per-substrate report (Task 1) + optional source YAML
// (Task 3). Both lookups are best-effort — missing files render an
// empty section / "not editable" placeholder rather than 500ing.
let report: SubstrateReport | null = null;
let specYamlText: string | null = null;
let specYamlStem: string | null = null;

if (project === "cad") {
  const m = model as CadModel;
  focusedGlb = m.glb + BUILD_BUST;
  focusedCameraOrbit = cadCameras[m.camera ?? "iso"] ?? cadCameras.iso ?? "55deg 75deg 200mm";
  focusedLabel = m.name;
  const reportKey = `../../../reports/${m.name}.json`;
  const raw = reportFiles[reportKey];
  if (raw) {
    try {
      report = JSON.parse(raw) as SubstrateReport;
    } catch {
      report = null;
    }
  }
  if (report?.spec_path) {
    // spec_path is relative to code/cad/ (e.g. "specs/tier2_compact.yaml").
    // import.meta.glob keys are relative to this file.
    const stem = report.spec_path.replace(/^specs\//, "").replace(/\.yaml$/, "");
    const yamlKey = `../../../../../cad/specs/${stem}.yaml`;
    if (specFiles[yamlKey]) {
      specYamlText = specFiles[yamlKey];
      specYamlStem = stem;
    }
  }
} else {
  const m = model as KicadModel;
  focusedGlb = `/models/kicad/${m.name}.glb${BUILD_BUST}`;
  focusedCameraOrbit =
    kicadCameras[m.camera ?? "iso"] ?? kicadCameras.iso ?? "55deg 75deg 200mm";
  focusedLabel = m.label ?? m.name;
  // KiCad's render-board produces an iso PNG alongside the GLB — use
  // it as a static fallback (and a thumbnail-style "image" in the
  // focused panel beside the interactive viewer).
  focusedImg = `/models/kicad/${m.name}-iso.png`;
}

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{focusedLabel} — 3dPCB-paper</title>
    <link rel="stylesheet" href="/style.css" />
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  </head>
  <body>
    <header class="header">
      <a href="/" class="back-link">&larr; gallery</a>
      <h1>{focusedLabel}</h1>
      <div class="header-status">
        <span class="build-status">{project}</span>
      </div>
    </header>

    <main class="content">
      <!-- Focus slot: large viewer for the URL-selected model. -->
      <section class="focus-slot">
        <div class="focus-pane">
          <model-viewer
            id="focus-viewer"
            src={focusedGlb}
            camera-controls
            auto-rotate
            camera-orbit={focusedCameraOrbit}
            shadow-intensity="1"
            exposure="0.9"
            alt={focusedLabel}
            style="width: 100%; height: min(85vh, 900px); min-height: 560px;"
          />
          <button
            id="focus-rotate-toggle"
            type="button"
            class="focus-rotate-btn"
            aria-label="Pause rotation"
          >⏸</button>
        </div>
        {
          focusedImg && (
            <aside class="focus-thumb">
              <h3>Iso render</h3>
              <img src={focusedImg} alt={`${focusedLabel} isometric render`} />
            </aside>
          )
        }
      </section>

      <!-- Downloads. The STL link is a plain `<a download>`; the
           "Open in OpenSCAD / KiCad" buttons POST to /api/open,
           which spawns the local app on the server. -->
      <section class="focus-downloads">
        {project === "cad" ? (
          <>
            <a class="dl-btn" href={`/models/cad/${(model as CadModel).name}.stl`} download>
              Download <strong>.stl</strong>
            </a>
            <button
              class="dl-btn"
              type="button"
              data-open-tool="openscad"
              data-open-name={(model as CadModel).name}
            >
              Open in <strong>OpenSCAD</strong>
            </button>
            <button id="regen-btn" class="dl-btn" type="button">
              Regenerate <strong>model</strong>
            </button>
            <span id="regen-status" class="muted"></span>
            <button
              id="print-btn"
              class="dl-btn"
              type="button"
              data-board={(model as CadModel).name}
            >
              Print on <strong>Bambu</strong>
            </button>
            <span id="print-status" class="muted"></span>
          </>
        ) : (
          (() => {
            const kname = (model as KicadModel).name;
            const pcbBase = kname.replace(/-assembly$/, "");
            return (
              <>
                <a class="dl-btn" href={`/models/kicad/${kname}.stl`} download>
                  Download <strong>.stl</strong>
                </a>
                <button
                  class="dl-btn"
                  type="button"
                  data-open-tool="kicad"
                  data-open-name={pcbBase}
                >
                  Open in <strong>KiCad</strong>
                </button>
              </>
            );
          })()
        )}
      </section>

      {project === "cad" && report && (
        <section class="substrate-report" aria-labelledby="report-heading">
          <h2 id="report-heading">Routing report</h2>
          <div class="report-grid">
            <div class="report-block">
              <h3>Scoring breakdown</h3>
              <dl class="report-dl">
                <dt>Total length</dt><dd>{report.score.total_length_mm.toFixed(2)} mm</dd>
                <dt>L1 length</dt><dd>{report.score.l1_length_mm.toFixed(2)} mm</dd>
                <dt>L2 length</dt><dd>{report.score.l2_length_mm.toFixed(2)} mm</dd>
                <dt>Via count</dt><dd>{report.score.via_count}</dd>
                <dt>Min edge clearance</dt><dd>{report.score.edge_clearance_min_mm.toFixed(2)} mm</dd>
                <dt>Pedestal-underside L1</dt><dd>{report.score.pedestal_underside_mm.toFixed(2)} mm</dd>
                <dt>Aggregate score</dt><dd><strong>{report.score.aggregate.toFixed(1)}</strong> <span class="muted">(lower is better)</span></dd>
              </dl>
            </div>
            {report.min_size && (
              <div class="report-block">
                <h3>Board size</h3>
                <dl class="report-dl">
                  <dt>Current</dt><dd>{report.min_size.current_width_mm.toFixed(2)} × {report.min_size.current_height_mm.toFixed(2)} mm</dd>
                  <dt>Minimum fit</dt><dd><strong>{report.min_size.width_mm.toFixed(2)} × {report.min_size.height_mm.toFixed(2)} mm</strong></dd>
                  <dt>Slack</dt><dd>{report.min_size.slack_width_mm.toFixed(2)} mm wide, {report.min_size.slack_height_mm.toFixed(2)} mm tall</dd>
                  <dt>Min perimeter</dt><dd class="muted">center_x {report.min_size.center_x.toFixed(2)}, center_y {report.min_size.center_y.toFixed(2)}, width {report.min_size.width_mm.toFixed(2)}, height {report.min_size.height_mm.toFixed(2)}</dd>
                </dl>
              </div>
            )}
            <div class="report-block">
              <h3>Routing invariants</h3>
              <ul class="report-invariants">
                {report.invariants.map((inv) => (
                  <li class={inv.passed ? "inv-pass" : "inv-fail"}>
                    <span class="inv-mark" aria-hidden="true">{inv.passed ? "✓" : "✗"}</span>
                    <span class="inv-label">{inv.label}</span>
                    <span class="inv-msg">{inv.message}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="report-block report-holes">
            <h3>Drilled holes ({report.holes.length})</h3>
            <table class="report-table">
              <thead><tr><th>name</th><th>x (mm)</th><th>y (mm)</th><th>⌀ (mm)</th></tr></thead>
              <tbody>
                {report.holes.map((h) => (
                  <tr>
                    <td>{h.name}</td>
                    <td>{h.x.toFixed(2)}</td>
                    <td>{h.y.toFixed(2)}</td>
                    <td>{h.diameter.toFixed(2)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {project === "cad" && !report && (
        <section class="substrate-report substrate-report-empty">
          <h2>Routing report</h2>
          <p class="muted">no routing report available for this model.</p>
        </section>
      )}

      {project === "cad" && specYamlText && specYamlStem && (
        <section class="spec-editor" aria-labelledby="spec-editor-heading">
          <h2 id="spec-editor-heading">Spec source — <code>specs/{specYamlStem}.yaml</code></h2>
          <p class="muted">Edit the spec, click Save. It re-renders the GLB and the report updates automatically.</p>
          <textarea
            id="spec-editor-textarea"
            data-spec-name={specYamlStem}
            spellcheck="false"
            rows="24"
          >{specYamlText}</textarea>
          <div class="spec-editor-actions">
            <button id="spec-save-btn" type="button" class="dl-btn">Save</button>
            <span id="spec-save-status" class="muted"></span>
          </div>
        </section>
      )}

      {project === "cad" && report && !specYamlText && (
        <section class="spec-editor spec-editor-disabled">
          <h2>Spec source</h2>
          <p class="muted">not editable — hand-coded class (<code>{report.class}</code>).</p>
        </section>
      )}

      <script is:inline>
        // POST the edited YAML to /api/save-spec (validates the path
        // stays under code/cad/specs/ and writes atomically), then
        // POST /api/rebuild to re-render. The watcher (watch-cad) only
        // watches code/cad/src/*.py, NOT the specs dir, so a spec edit
        // would otherwise never trigger a rebuild — driving the render
        // explicitly here is what makes Save → re-render actually work.
        (function () {
          const ta = document.getElementById("spec-editor-textarea");
          const btn = document.getElementById("spec-save-btn");
          const status = document.getElementById("spec-save-status");
          if (!ta || !btn || !status) return;
          btn.addEventListener("click", async () => {
            btn.disabled = true;
            status.textContent = "saving…";
            try {
              const res = await fetch("/api/save-spec", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  name: ta.dataset.specName,
                  yaml: ta.value,
                }),
              });
              const body = await res.json().catch(() => ({}));
              if (!res.ok || !body || !body.ok) {
                status.textContent = "save failed: " + (body && body.error ? body.error : res.statusText);
                return;
              }
              status.textContent = "saved ✓ — regenerating…";
              const rb = await fetch("/api/rebuild", { method: "POST" });
              const rbody = await rb.json().catch(() => ({}));
              if (rb.ok && rbody && rbody.ok) {
                status.textContent = "saved ✓ — rebuilt, viewer refreshing";
              } else {
                const err = (rbody && (rbody.error || rbody.message)) || rb.statusText;
                status.textContent = "saved ✓ but rebuild failed: " + err;
              }
            } catch (e) {
              status.textContent = "network error: " + e;
            } finally {
              btn.disabled = false;
            }
          });
        })();
      </script>

      <script type="module">
        // Task 2: hot-reload listener. The dev plugin in astro.config.mjs
        // watches public/models/cad/ and pushes a `glb-changed` event
        // with `{ path, mtime }` over Vite's HMR socket whenever a GLB
        // is rewritten by the watcher. We swap the focus viewer's `src`
        // to `<path>?t=<mtime>` — model-viewer reloads on src change
        // and the new mtime invalidates the browser cache key.
        if (import.meta.hot) {
          import.meta.hot.on("glb-changed", (data) => {
            if (!data || !data.path) return;
            document.querySelectorAll("model-viewer").forEach((mv) => {
              const src = mv.getAttribute("src");
              if (!src) return;
              const base = src.split("?")[0];
              if (base !== data.path) return;
              const t = data.mtime || Date.now();
              mv.setAttribute("src", `${base}?t=${t}`);
            });
          });
          // Reports are inlined at SSR via ?raw; rebuild → file mtime
          // bumps → ?raw cache miss → we reload to pick up new numbers.
          import.meta.hot.on("report-changed", () => location.reload());
          // Manifest changes can rename / add / remove substrate entries
          // that this page depends on via getStaticPaths — the plugin
          // invalidates the focus page module, so a reload re-resolves
          // the route against the fresh manifest.
          import.meta.hot.on("manifest-changed", () => location.reload());
        }
      </script>

      <script is:inline>
        // Regenerate button: POST /api/rebuild to re-run the CAD render
        // pipeline (the same prebuild-cad the watcher runs). On success
        // the dev plugin's fs.watch fires glb-changed / report-changed,
        // which swaps the viewer src and reloads the report — so no
        // manual refresh is needed.
        (function () {
          const btn = document.getElementById("regen-btn");
          const status = document.getElementById("regen-status");
          if (!btn || !status) return;
          btn.addEventListener("click", async () => {
            btn.disabled = true;
            status.textContent = "regenerating… (rendering all CAD parts)";
            try {
              const res = await fetch("/api/rebuild", { method: "POST" });
              const body = await res.json().catch(() => ({}));
              if (res.ok && body && body.ok) {
                status.textContent = "rebuilt ✓ — viewer refreshing";
              } else {
                const err = (body && (body.error || body.message)) || res.statusText;
                status.textContent = "rebuild failed: " + err;
              }
            } catch (e) {
              status.textContent = "network error: " + e;
            } finally {
              btn.disabled = false;
            }
          });
        })();
      </script>

      <script is:inline>
        // Print button: POSTs {board} to /api/printer/print, then polls
        // /api/printer/print/status every second until the bridge's
        // slice→upload→start pipeline finishes. Once the bridge says
        // "started", live progress is on the /printer page (driven by
        // MQTT pushes — no further work here).
        (function () {
          const btn = document.getElementById("print-btn");
          const status = document.getElementById("print-status");
          if (!btn || !status) return;
          const board = btn.dataset.board;
          if (!board) return;
          btn.addEventListener("click", async () => {
            if (!confirm(`Slice "${board}" and print it on the Bambu P2S?`)) return;
            btn.disabled = true;
            status.textContent = "queueing…";
            let res;
            try {
              res = await fetch("/api/printer/print", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ board }),
              });
            } catch (e) {
              status.textContent = "network error: " + e;
              btn.disabled = false;
              return;
            }
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              status.textContent = "failed: " + (body.error || res.statusText);
              btn.disabled = false;
              return;
            }
            // Poll the bridge's job state. Slice ~30s, upload <1s, MQTT
            // start ~1s — give it 90s before giving up on a clean phase.
            const deadline = Date.now() + 90_000;
            const poll = setInterval(async () => {
              let s;
              try {
                s = await fetch("/api/printer/print/status").then((r) => r.json());
              } catch (e) {
                status.textContent = "poll error: " + e;
                return;
              }
              const phase = s.phase || "?";
              status.textContent = `${phase}${s.error ? " — " + s.error : ""}`;
              if (!s.running) {
                clearInterval(poll);
                btn.disabled = false;
                if (phase === "started") {
                  status.innerHTML = `started ✓ — <a href="/printer">live status</a>`;
                }
                return;
              }
              if (Date.now() > deadline) {
                clearInterval(poll);
                btn.disabled = false;
                status.textContent = `timed out polling at phase ${phase}`;
              }
            }, 1000);
          });
        })();
      </script>

      <script is:inline>
        // Pause / resume the model-viewer's auto-rotate. State persists
        // in localStorage under the model's URL path so a refresh stays
        // paused for the same model.
        (function () {
          const mv = document.getElementById("focus-viewer");
          const btn = document.getElementById("focus-rotate-toggle");
          if (!mv || !btn) return;
          const key = "gallery:focus-paused:" + location.pathname;
          const apply = (paused) => {
            if (paused) mv.removeAttribute("auto-rotate");
            else mv.setAttribute("auto-rotate", "");
            btn.textContent = paused ? "▶" : "⏸";
            btn.setAttribute("aria-label", paused ? "Resume rotation" : "Pause rotation");
          };
          apply(localStorage.getItem(key) === "1");
          btn.addEventListener("click", () => {
            const next = mv.hasAttribute("auto-rotate");  // currently rotating → pause
            localStorage.setItem(key, next ? "1" : "0");
            apply(next);
          });
        })();
      </script>

      <script is:inline>
        // CRITICAL: dev-mode wiring for the "Open in …" buttons.
        // POST to /api/open; the server spawns the local app with
        // the named source file. Same handler covers both projects.
        document.addEventListener("click", async (ev) => {
          const btn = ev.target?.closest?.("button[data-open-tool]");
          if (!btn) return;
          const original = btn.innerHTML;
          btn.disabled = true;
          btn.textContent = "Launching…";
          try {
            const res = await fetch("/api/open", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                tool: btn.dataset.openTool,
                name: btn.dataset.openName,
              }),
            });
            btn.textContent = res.ok ? "Launched ✓" : "Failed";
          } catch (e) {
            btn.textContent = "Network error";
          }
          setTimeout(() => {
            btn.innerHTML = original;
            btn.disabled = false;
          }, 1800);
        });
      </script>

    </main>
  </body>
</html>
