---
// Stay prerendered as static HTML even though the project is now
// `output: 'server'` — only /api/open needs to be SSR.
export const prerender = true;

// Gallery index. Reads the cad + kicad manifests at build time and
// renders one <model-viewer> card per registered AnchorSCAD part / KiCad
// board.
//
// Vite's `?raw` query inlines the YAML at build time, which keeps
// Astro happy under both dev (HMR) and SSG (no need to copy files
// into the prerender chunk dir). For directory enumeration we use
// `import.meta.glob({ query: '?raw' })` which gives us a synchronous
// (eager) record of every YAML inlined as a string.
import { parse as parseYaml } from "yaml";
import cadManifestYaml from "../manifest.cad.yaml?raw";
import kicadManifestYaml from "../manifest.kicad.yaml?raw";
import vitaminsManifestYaml from "../manifest.vitamins.yaml?raw";

const placementYamls = import.meta.glob<string>(
  "../../../kicad/placements/*.yaml",
  { query: "?raw", import: "default", eager: true },
);

interface CadModel {
  name: string;
  glb: string;
  camera?: string;
  // `vitamin` flags AnchorSCAD-built approximations of off-the-shelf
  // parts (sensors, modules). Omitted entries are treated as substrate
  // / carrier / assembly and rendered at the larger size.
  type?: "vitamin";
}

interface CadManifest {
  project: string;
  cameras?: Record<string, string>;
  models: CadModel[];
}

// Append build-time cache-buster to GLB URLs — model-viewer caches
// by exact URL, so re-rendered GLBs without this would serve stale
// geometry until the browser hard-reloads twice.
const BUILD_BUST = `?v=${Date.now()}`;

const cad = parseYaml(cadManifestYaml) as CadManifest;
const cameras = cad.cameras ?? {};
const cardModels = cad.models.map((m) => ({
  ...m,
  glb: m.glb + BUILD_BUST,
  cameraOrbit: cameras[m.camera ?? "iso"] ?? cameras.iso,
}));
const substrateCards = cardModels.filter((m) => m.type !== "vitamin");
const cadVitaminCards = cardModels.filter((m) => m.type === "vitamin");

// KiCad manifest — populated by hand as .kicad_pcb files land; the
// prebuild script (bin/prebuild-kicad) stages matching GLB + iso PNG
// into public/models/kicad/.
type KicadModel = { name: string; label?: string; camera?: string };
type KicadManifest = {
  project: string;
  models: KicadModel[];
  cameras?: Record<string, string>;
};
const kicadManifest = parseYaml(kicadManifestYaml) as KicadManifest;
const kicadModels: KicadModel[] = kicadManifest.models ?? [];

// Third-party vitamins manifest — STEP / STP sources under data/models/
// are converted to GLB by bin/prebuild-vitamins and staged into
// public/models/vitamins/. The source file is staged alongside for
// download; `license` annotates the upstream terms.
interface VitaminModel {
  name: string;
  label?: string;
  source: string;
  license?: string;
  camera?: string;
}
interface VitaminsManifest {
  project: string;
  models: VitaminModel[];
  cameras?: Record<string, string>;
}
const vitaminsManifest = parseYaml(vitaminsManifestYaml) as VitaminsManifest;
const vitaminCameras = vitaminsManifest.cameras ?? {};
const vitaminCards = (vitaminsManifest.models ?? []).map((m) => ({
  ...m,
  sourceBasename: m.source.split("/").pop() ?? m.source,
  cameraOrbit: vitaminCameras[m.camera ?? "iso"] ?? vitaminCameras.iso,
}));

// Embodiment pairs — substrate variants pairing a substrate GLB with a
// KiCad PCB. Each YAML under code/kicad/placements/ becomes one entry.
interface Placement {
  id: string;
  label?: string;
  pcb: string;
  substrate: { glb: string; camera?: string };
}
const placements: Placement[] = Object.values(placementYamls).map(
  (raw) => parseYaml(raw) as Placement,
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>3dPCB-paper gallery</title>
    <link rel="stylesheet" href="/style.css" />
    <!-- model-viewer registers <model-viewer> as a custom element on import. -->
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  </head>
  <body>
    <header class="header">
      <h1>3dPCB-paper gallery</h1>
      <div class="header-status">
        <span class="build-status">{substrateCards.length} substrate part(s) · {cadVitaminCards.length + vitaminCards.length} vitamin(s)</span>
      </div>
    </header>

    <main class="content">
      <!-- Pinned section — populated client-side from localStorage.
           Hidden when empty; cards are cloned in from the sections below. -->
      <section class="model-group" id="pinned-section" hidden>
        <div class="model-group-header">
          <h2>Pinned</h2>
          <span class="muted">stored locally in this browser</span>
        </div>
        <div class="screenshot-grid large" id="pinned-grid"></div>
      </section>

      {
        substrateCards.length === 0 ? (
          <div class="empty-state">
            <h2>No models yet</h2>
            <p>
              Run <code>bun run build</code> from <code>code/web/</code> to
              invoke the AnchorSCAD render pipeline.
            </p>
          </div>
        ) : (
          <section class="model-group">
            <div class="model-group-header">
              <h2>AnchorSCAD substrate ({cad.project})</h2>
            </div>
            <div class="screenshot-grid large">
              {substrateCards.map((m) => (
                <article class="screenshot-card" data-pin-id={`cad/${m.name}`} data-pin-label={m.name}>
                  <a class="screenshot-card-link" href={`/model/cad/${m.name}/`}>
                    <model-viewer
                      src={m.glb}
                      camera-controls
                      auto-rotate
                      camera-orbit={m.cameraOrbit}
                      shadow-intensity="1"
                      exposure="0.9"
                      alt={m.name}
                    />
                    <div class="card-footer">
                      <span class="angle-label">{cad.project}</span>
                      <span>{m.name}</span>
                    </div>
                  </a>
                  <div class="card-controls">
                    <button type="button" class="ctrl-pin" data-action="pin" title="Pin to top">☆</button>
                    <button type="button" class="ctrl-rotate" data-action="autorotate" title="Toggle auto-rotate">⟳</button>
                  </div>
                  <div class="card-downloads">
                    <a href={`/models/cad/${m.name}.stl`} download>STL</a>
                    <span class="dot">·</span>
                    <button
                      type="button"
                      data-open-tool="openscad"
                      data-open-name={m.name}
                      title="Launch OpenSCAD on the server with this file"
                    >Open SCAD</button>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        cadVitaminCards.length > 0 && (
          <section class="model-group">
            <div class="model-group-header">
              <h2>AnchorSCAD vitamins</h2>
              <span class="muted">COTS approximations built in Python</span>
            </div>
            <div class="screenshot-grid">
              {cadVitaminCards.map((m) => (
                <article class="screenshot-card" data-pin-id={`cad/${m.name}`} data-pin-label={m.name}>
                  <a class="screenshot-card-link" href={`/model/cad/${m.name}/`}>
                    <model-viewer
                      src={m.glb}
                      camera-controls
                      auto-rotate
                      camera-orbit={m.cameraOrbit}
                      shadow-intensity="1"
                      exposure="0.9"
                      alt={m.name}
                    />
                    <div class="card-footer">
                      <span class="angle-label">vitamin</span>
                      <span>{m.name}</span>
                    </div>
                  </a>
                  <div class="card-controls">
                    <button type="button" class="ctrl-pin" data-action="pin" title="Pin to top">☆</button>
                    <button type="button" class="ctrl-rotate" data-action="autorotate" title="Toggle auto-rotate">⟳</button>
                  </div>
                  <div class="card-downloads">
                    <a href={`/models/cad/${m.name}.stl`} download>STL</a>
                    <span class="dot">·</span>
                    <button
                      type="button"
                      data-open-tool="openscad"
                      data-open-name={m.name}
                      title="Launch OpenSCAD on the server with this file"
                    >Open SCAD</button>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      <!-- Embodiment pairs section -->
      <section class="model-group embodiment">
        <div class="model-group-header">
          <h2>Embodiment pairs</h2>
        </div>
        {
          placements.length === 0 ? (
            <p class="empty-state-inline">
              no placements yet &mdash; see <code>code/kicad/placements/</code>
            </p>
          ) : (
            <ul class="embodiment-list">
              {placements.map((p) => (
                <li>
                  <a href={`/embodiment/${p.id}/`}>
                    <strong>{p.label ?? p.id}</strong>
                    <span class="muted">
                      {p.pcb} ⇄ {p.substrate.glb}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </section>
      <!-- /Embodiment pairs section -->

      <!-- KiCad gallery section -->
      <section class="model-group gallery kicad">
        <div class="model-group-header">
          <h2>KiCad</h2>
        </div>
        {
          kicadModels.length === 0 ? (
            <p class="empty-state-inline">
              no boards rendered yet &mdash; see <code>code/kicad/</code>
            </p>
          ) : (
            <div class="screenshot-grid">
              {kicadModels.map((m) => {
                // Strip any -assembly suffix to find the underlying
                // PCB source (only spike.kicad_pcb exists, not
                // spike-assembly.kicad_pcb). STL follows the same
                // {name}.stl pattern; assembly variants don't have
                // their own STL.
                const pcbBase = m.name.replace(/-assembly$/, "");
                return (
                  <article class="screenshot-card" data-pin-id={`kicad/${m.name}`} data-pin-label={m.label ?? m.name}>
                    <a class="screenshot-card-link" href={`/model/kicad/${m.name}/`}>
                      <model-viewer
                        src={`/models/kicad/${m.name}.glb${BUILD_BUST}`}
                        alt={m.label ?? m.name}
                        camera-controls
                        auto-rotate
                      />
                      <div class="card-footer">
                        <span class="angle-label">kicad</span>
                        <span>{m.label ?? m.name}</span>
                      </div>
                    </a>
                    <div class="card-controls">
                      <button type="button" class="ctrl-pin" data-action="pin" title="Pin to top">☆</button>
                      <button type="button" class="ctrl-rotate" data-action="autorotate" title="Toggle auto-rotate">⟳</button>
                    </div>
                    <div class="card-downloads">
                      <a href={`/models/kicad/${m.name}.stl`} download>STL</a>
                      <span class="dot">·</span>
                      <button
                        type="button"
                        data-open-tool="kicad"
                        data-open-name={pcbBase}
                        title="Launch KiCad on the server with this board"
                      >Open KiCad</button>
                    </div>
                  </article>
                );
              })}
            </div>
          )
        }
      </section>
      <!-- /KiCad gallery section -->

      <!-- Third-party vitamins gallery section -->
      <section class="model-group gallery vitamins">
        <div class="model-group-header">
          <h2>Vitamins / COTS</h2>
          <span class="muted">upstream STEP from vendors</span>
        </div>
        {
          vitaminCards.length === 0 ? (
            <p class="empty-state-inline">
              no vitamins staged yet &mdash; see <code>data/models/</code>
            </p>
          ) : (
            <div class="screenshot-grid">
              {vitaminCards.map((m) => (
                <article class="screenshot-card" data-pin-id={`vitamin/${m.name}`} data-pin-label={m.label ?? m.name}>
                  <model-viewer
                    src={`/models/vitamins/${m.name}.glb${BUILD_BUST}`}
                    alt={m.label ?? m.name}
                    camera-controls
                    auto-rotate
                    camera-orbit={m.cameraOrbit}
                    shadow-intensity="1"
                    exposure="0.9"
                  />
                  <div class="card-footer">
                    <span class="angle-label">vitamin</span>
                    <span>{m.label ?? m.name}</span>
                  </div>
                  <div class="card-controls">
                    <button type="button" class="ctrl-pin" data-action="pin" title="Pin to top">☆</button>
                    <button type="button" class="ctrl-rotate" data-action="autorotate" title="Toggle auto-rotate">⟳</button>
                  </div>
                  <div class="card-downloads">
                    <a href={`/models/vitamins/${m.sourceBasename}`} download>STEP</a>
                    {m.license && (
                      <>
                        <span class="dot">·</span>
                        <span class="license-tag" title="upstream license">{m.license}</span>
                      </>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </section>
      <!-- /Third-party vitamins gallery section -->
    </main>

    <!-- Lightbox shell ported from cadeng; wired up in a later PR. -->
    <div id="lightbox" class="lightbox">
      <button class="lightbox-close" type="button">&times;</button>
      <div id="lightbox-body"></div>
      <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>

    <script is:inline>
      // "Open" buttons POST to /api/open which spawns OpenSCAD or
      // KiCad on the server with the named source file. Single
      // handler covers every card on the page.
      document.addEventListener("click", async (ev) => {
        const btn = ev.target?.closest?.("button[data-open-tool]");
        if (!btn) return;
        const original = btn.innerHTML;
        btn.disabled = true;
        btn.textContent = "…";
        try {
          const res = await fetch("/api/open", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              tool: btn.dataset.openTool,
              name: btn.dataset.openName,
            }),
          });
          btn.textContent = res.ok ? "✓" : "✗";
        } catch (e) {
          btn.textContent = "✗";
        }
        setTimeout(() => {
          btn.innerHTML = original;
          btn.disabled = false;
        }, 1500);
      });
    </script>

    <script is:inline>
      // Pinning + per-card auto-rotate, both persisted in localStorage.
      //
      // PIN_KEY stores a JSON array of pin-ids (matches data-pin-id on
      // each .screenshot-card). When a card is pinned, we clone it into
      // #pinned-grid at the top of the page and add .is-pinned-source
      // to the original so the user knows where it came from.
      //
      // ROTATE_KEY stores { [pinId]: false } — only "off" overrides are
      // persisted; absence means default-on (matches the markup).
      const PIN_KEY = "gallery:pinned";
      const ROTATE_KEY = "gallery:autorotate";

      const loadJSON = (k, fallback) => {
        try { return JSON.parse(localStorage.getItem(k) ?? "") ?? fallback; }
        catch { return fallback; }
      };
      const saveJSON = (k, v) => localStorage.setItem(k, JSON.stringify(v));

      let pinned = loadJSON(PIN_KEY, []);
      const rotateOverrides = loadJSON(ROTATE_KEY, {});

      const pinnedSection = document.getElementById("pinned-section");
      const pinnedGrid = document.getElementById("pinned-grid");

      function applyAutoRotate(card, pinId) {
        const off = rotateOverrides[pinId] === false;
        const mv = card.querySelector("model-viewer");
        if (mv) {
          if (off) mv.removeAttribute("auto-rotate");
          else mv.setAttribute("auto-rotate", "");
        }
        const btn = card.querySelector('[data-action="autorotate"]');
        if (btn) btn.classList.toggle("is-off", off);
      }

      function refreshPinned() {
        pinnedGrid.innerHTML = "";
        document.querySelectorAll(".screenshot-card[data-pin-id]").forEach((c) => {
          c.classList.remove("is-pinned-source");
        });
        if (pinned.length === 0) {
          pinnedSection.hidden = true;
          return;
        }
        pinnedSection.hidden = false;
        pinned.forEach((pinId) => {
          const source = document.querySelector(
            `.screenshot-card[data-pin-id="${CSS.escape(pinId)}"]:not(.pinned-clone)`,
          );
          if (!source) return;
          source.classList.add("is-pinned-source");
          const clone = source.cloneNode(true);
          clone.classList.add("pinned-clone");
          pinnedGrid.appendChild(clone);
          applyAutoRotate(clone, pinId);
          // Mark its pin button so the user sees it's already pinned.
          const pinBtn = clone.querySelector('[data-action="pin"]');
          if (pinBtn) {
            pinBtn.textContent = "★";
            pinBtn.classList.add("is-pinned");
          }
        });
        // Refresh the source-card pin buttons too.
        document.querySelectorAll('.screenshot-card[data-pin-id]:not(.pinned-clone)').forEach((c) => {
          const pinBtn = c.querySelector('[data-action="pin"]');
          if (!pinBtn) return;
          const isPinned = pinned.includes(c.dataset.pinId);
          pinBtn.textContent = isPinned ? "★" : "☆";
          pinBtn.classList.toggle("is-pinned", isPinned);
        });
      }

      // Apply persisted auto-rotate state to every original card on first paint.
      document.querySelectorAll(".screenshot-card[data-pin-id]").forEach((c) => {
        applyAutoRotate(c, c.dataset.pinId);
      });

      refreshPinned();

      document.addEventListener("click", (ev) => {
        const btn = ev.target?.closest?.("button[data-action]");
        if (!btn) return;
        const card = btn.closest(".screenshot-card");
        if (!card) return;
        const pinId = card.dataset.pinId;
        if (!pinId) return;

        if (btn.dataset.action === "pin") {
          ev.preventDefault();
          const idx = pinned.indexOf(pinId);
          if (idx >= 0) pinned.splice(idx, 1);
          else pinned.push(pinId);
          saveJSON(PIN_KEY, pinned);
          refreshPinned();
        } else if (btn.dataset.action === "autorotate") {
          ev.preventDefault();
          const currentOff = rotateOverrides[pinId] === false;
          if (currentOff) delete rotateOverrides[pinId];
          else rotateOverrides[pinId] = false;
          saveJSON(ROTATE_KEY, rotateOverrides);
          // Apply to every card with this pin-id (source + clone).
          document
            .querySelectorAll(`.screenshot-card[data-pin-id="${CSS.escape(pinId)}"]`)
            .forEach((c) => applyAutoRotate(c, pinId));
        }
      });
    </script>

    <script type="module">
      // Task 2 / live refresh: when the dev plugin pushes a glb-changed
      // event for any model on the page, swap that <model-viewer>'s src
      // (with a fresh ?t=<mtime>) so model-viewer re-fetches the GLB.
      // The pinned-cards section holds cloned <model-viewer> nodes too,
      // so we update every match (querySelectorAll).
      if (import.meta.hot) {
        import.meta.hot.on("glb-changed", (data) => {
          if (!data || !data.path) return;
          document.querySelectorAll("model-viewer").forEach((mv) => {
            const src = mv.getAttribute("src");
            if (!src) return;
            const base = src.split("?")[0];
            if (base !== data.path) return;
            const t = data.mtime || Date.now();
            mv.setAttribute("src", `${base}?t=${t}`);
          });
        });
        // A manifest rewrite means new/removed cards — the index
        // page module has already been invalidated server-side, so
        // a reload pulls fresh HTML.
        import.meta.hot.on("manifest-changed", () => location.reload());
      }
    </script>
  </body>
</html>
