---
// Live printer status. Polls /api/printer/status (which proxies the
// bambu-bridge UDS sidecar) every 2 seconds. No printer auth lives
// on this page — the bridge holds it.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Printer · 3dPCB</title>
    <style>
      body {
        font: 14px/1.4 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        max-width: 760px;
        margin: 2rem auto;
        padding: 0 1rem;
        color: #111;
        background: #fafafa;
      }
      h1 { font-size: 1.1rem; margin-bottom: 1.5rem; }
      .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 0.8rem;
        font-weight: 600;
      }
      .b-connected { background: #d3f0d4; color: #1d5a23; }
      .b-disconnected { background: #fae0e0; color: #8a1f1f; }
      .b-finish { background: #e7e7e7; color: #555; }
      .b-running { background: #d3e6ff; color: #1d4373; }
      .b-pause { background: #fff0c8; color: #7a5a0e; }
      .b-failed { background: #fae0e0; color: #8a1f1f; }
      .badges { display: grid; grid-template-columns: 6rem 1fr; row-gap: 0.4rem; max-width: 30rem; margin-bottom: 1rem; }
      .badges .label { color: #666; align-self: center; }
      dl {
        display: grid;
        grid-template-columns: 11rem 1fr;
        row-gap: 0.4rem;
        margin: 1rem 0;
      }
      dt { color: #666; }
      dd { margin: 0; }
      .bar {
        height: 6px;
        background: #ddd;
        border-radius: 3px;
        overflow: hidden;
        margin: 4px 0;
        max-width: 320px;
      }
      .bar > div {
        height: 100%;
        background: #1d4373;
        transition: width 0.4s ease;
      }
      .muted { color: #888; }
      .err {
        margin-top: 1rem;
        padding: 0.6rem 0.8rem;
        background: #fae0e0;
        color: #8a1f1f;
        border-radius: 3px;
      }
      .cam-section { margin-top: 2rem; }
      .cam-section h2 { font-size: 0.95rem; margin: 0 0 0.6rem; }
      .cam-controls { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.6rem; }
      .cam-controls button {
        padding: 4px 12px; border: 1px solid #ccc; background: #fff;
        border-radius: 3px; cursor: pointer; font: inherit;
      }
      .cam-controls button:disabled { opacity: 0.5; cursor: default; }
      .cam-frame {
        display: block; max-width: 100%;
        border: 1px solid #ddd; background: #000; aspect-ratio: 16/9;
      }
      .cam-frame.hidden { display: none; }
      .ctrl-section { margin-top: 2rem; }
      .ctrl-section h2 { font-size: 0.95rem; margin: 0 0 0.6rem; }
      .ctrl-row {
        display: grid; grid-template-columns: 10rem 1fr; row-gap: 0.4rem;
        align-items: center; margin-bottom: 0.4rem; max-width: 36rem;
      }
      .ctrl-row .label { color: #666; }
      .ctrl-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; }
      .ctrl-buttons button {
        padding: 3px 10px; border: 1px solid #ccc; background: #fff;
        border-radius: 3px; cursor: pointer; font: inherit; font-size: 0.85rem;
      }
      .ctrl-buttons button:disabled { opacity: 0.5; cursor: default; }
      .ctrl-buttons button.active {
        background: #1d4373; color: #fff; border-color: #1d4373;
      }
      .ctrl-buttons button.danger:hover { background: #fae0e0; color: #8a1f1f; border-color: #8a1f1f; }
      #ctrl-msg { margin-top: 0.4rem; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <h1>Printer status <span class="muted">— polled live from bambu-bridge</span></h1>

    <div id="root">
      <p class="muted">connecting…</p>
    </div>

    <section class="cam-section">
      <h2>Camera</h2>
      <div class="cam-controls">
        <button id="cam-toggle" type="button">Start camera</button>
        <span id="cam-msg" class="muted">stopped</span>
      </div>
      <img id="cam-frame" class="cam-frame hidden" alt="live frame" />
    </section>

    <section class="ctrl-section">
      <h2>Controls</h2>
      <div class="ctrl-row">
        <span class="label">Job</span>
        <div class="ctrl-buttons">
          <button data-print-cmd="pause" type="button">Pause</button>
          <button data-print-cmd="resume" type="button">Resume</button>
          <button data-print-cmd="stop" class="danger" type="button" data-confirm="Stop the running print? This cannot be undone.">Stop</button>
        </div>
      </div>
      <div class="ctrl-row">
        <span class="label">Chamber light</span>
        <div class="ctrl-buttons" data-light-node="chamber_light">
          <button data-light-mode="on" type="button">On</button>
          <button data-light-mode="off" type="button">Off</button>
        </div>
      </div>
      <div class="ctrl-row">
        <span class="label">Work light</span>
        <div class="ctrl-buttons" data-light-node="work_light">
          <button data-light-mode="on" type="button">On</button>
          <button data-light-mode="off" type="button">Off</button>
          <button data-light-mode="flashing" type="button">Flashing</button>
        </div>
      </div>
      <div id="ctrl-msg" class="muted"></div>
    </section>

    <script is:inline>
      const fmt = (v, suffix = "") =>
        v === null || v === undefined ? '<span class="muted">—</span>' : v + suffix;

      function badge(label, klass) {
        return `<span class="badge b-${klass}">${label}</span>`;
      }

      function gcodeBadge(state) {
        const k = (state || "").toLowerCase() || "finish";
        const known = ["finish", "running", "pause", "failed"];
        return badge(state || "unknown", known.includes(k) ? k : "finish");
      }

      async function tick() {
        let res, body;
        try {
          res = await fetch("/api/printer/status", { cache: "no-store" });
          body = await res.json();
        } catch (err) {
          render({ error: "fetch_failed", detail: String(err) });
          return;
        }
        if (!res.ok) {
          render({ error: body.error ?? "unknown", detail: body.detail ?? "" });
          return;
        }
        render(body);
      }

      function render(s) {
        const root = document.getElementById("root");
        if (s.error) {
          root.innerHTML = `<div class="err"><strong>${s.error}</strong><br>${s.detail || ""}</div>`;
          return;
        }
        const p = s.print || {};
        const pct = p.mc_percent ?? 0;
        const linkConn = badge(
          s.connected ? "MQTT connected" : "MQTT disconnected",
          s.connected ? "connected" : "disconnected",
        );
        const stale =
          s.stale_seconds === null
            ? '<span class="muted">no push yet</span>'
            : s.stale_seconds.toFixed(1) + "s ago";
        const noz = fmt(p.nozzle_temper, " °C") +
          (p.nozzle_target_temper ? ` <span class="muted">→ ${p.nozzle_target_temper} °C</span>` : "");
        const bed = fmt(p.bed_temper, " °C") +
          (p.bed_target_temper ? ` <span class="muted">→ ${p.bed_target_temper} °C</span>` : "");
        root.innerHTML = `
          <div class="badges">
            <span class="label">Bridge link</span><span>${linkConn}</span>
            <span class="label">Print state</span><span>${gcodeBadge(p.gcode_state)}</span>
          </div>
          <dl>
            <dt>Job</dt><dd>${fmt(p.subtask_name)}</dd>
            <dt>Progress</dt>
            <dd>${pct}%
              <div class="bar"><div style="width:${pct}%"></div></div>
              layer ${fmt(p.layer_num)} / ${fmt(p.total_layer_num)}
            </dd>
            <dt>Remaining</dt><dd>${fmt(p.mc_remaining_time, " min")}</dd>
            <dt>Nozzle</dt><dd>${noz}</dd>
            <dt>Bed</dt><dd>${bed}</dd>
            <dt>Stage code</dt><dd>${fmt(p.stg_cur)}</dd>
            <dt>Last push</dt><dd>${stale}</dd>
          </dl>
        `;
      }

      tick();
      setInterval(tick, 2000);

      // Controls: print job (pause/resume/stop) + light (chamber/work, on/off/flashing).
      // The currently-active light mode is read from the printer's lights_report
      // (broadcast in every status push) so the right button stays highlighted.
      (function () {
        const ctrlMsg = document.getElementById("ctrl-msg");
        function flash(text, isError) {
          ctrlMsg.textContent = text;
          ctrlMsg.className = isError ? "err" : "muted";
          setTimeout(() => { ctrlMsg.textContent = ""; ctrlMsg.className = "muted"; }, 4000);
        }

        async function post(path, body) {
          const res = await fetch(path, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok) {
            throw new Error(json.error || res.statusText);
          }
          return json;
        }

        document.querySelectorAll("button[data-print-cmd]").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const cmd = btn.dataset.printCmd;
            const need = btn.dataset.confirm;
            if (need && !confirm(need)) return;
            btn.disabled = true;
            try {
              await post("/api/printer/control/print", { command: cmd });
              flash(`sent: ${cmd}`, false);
            } catch (e) {
              flash(`${cmd} failed: ${e.message}`, true);
            } finally {
              btn.disabled = false;
            }
          });
        });

        document.querySelectorAll(".ctrl-buttons[data-light-node]").forEach((group) => {
          const node = group.dataset.lightNode;
          group.querySelectorAll("button[data-light-mode]").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const mode = btn.dataset.lightMode;
              btn.disabled = true;
              try {
                await post("/api/printer/control/light", { node, mode });
                flash(`${node}: ${mode}`, false);
              } catch (e) {
                flash(`${node} ${mode} failed: ${e.message}`, true);
              } finally {
                btn.disabled = false;
              }
            });
          });
        });

        // Reflect live light state from the status payload so the active
        // mode button highlights. Hook into the main tick by re-reading
        // the same status endpoint on a slower cadence.
        async function reflectLights() {
          try {
            const s = await fetch("/api/printer/status").then((r) => r.json());
            const lights = (s.print || {}).lights_report || [];
            const map = {};
            for (const l of lights) map[l.node] = l.mode;
            document.querySelectorAll(".ctrl-buttons[data-light-node]").forEach((group) => {
              const cur = map[group.dataset.lightNode];
              group.querySelectorAll("button[data-light-mode]").forEach((btn) => {
                btn.classList.toggle("active", btn.dataset.lightMode === cur);
              });
            });
          } catch {}
        }
        reflectLights();
        setInterval(reflectLights, 3000);
      })();

      // Camera: POST /camera/start, swap <img src> to the MJPEG stream.
      // Stop button POSTs /camera/stop and clears src so the browser
      // tears the multipart consumer connection down. The bridge owns
      // the one ffmpeg subprocess; all tabs share its frame buffer.
      (function () {
        const btn = document.getElementById("cam-toggle");
        const msg = document.getElementById("cam-msg");
        const img = document.getElementById("cam-frame");
        let running = false;

        async function refreshStatus() {
          try {
            const s = await fetch("/api/printer/camera/status").then((r) => r.json());
            running = !!s.running;
            applyState();
            if (s.error) msg.textContent = "error: " + s.error;
            else if (running) {
              const age = s.frame_age == null ? "no frames yet" : s.frame_age.toFixed(1) + "s old";
              msg.textContent = `running · last frame ${age} · ${s.subscribers ?? 0} viewers`;
            }
          } catch (e) {
            msg.textContent = "status error: " + e;
          }
        }

        function applyState() {
          btn.textContent = running ? "Stop camera" : "Start camera";
          if (running) {
            if (img.classList.contains("hidden")) {
              img.src = "/api/printer/camera/stream";
              img.classList.remove("hidden");
            }
          } else {
            img.src = "";
            img.classList.add("hidden");
          }
        }

        btn.addEventListener("click", async () => {
          btn.disabled = true;
          msg.textContent = running ? "stopping…" : "starting…";
          try {
            const path = running ? "/api/printer/camera/stop" : "/api/printer/camera/start";
            const res = await fetch(path, { method: "POST" });
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              msg.textContent = "failed: " + (body.error || res.statusText);
              btn.disabled = false;
              return;
            }
            running = !running;
            applyState();
          } catch (e) {
            msg.textContent = "network error: " + e;
          } finally {
            btn.disabled = false;
          }
        });

        refreshStatus();
        setInterval(refreshStatus, 3000);
      })();
    </script>
  </body>
</html>
