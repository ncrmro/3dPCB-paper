#!/usr/bin/env bash
# Prebuild step for the CAD half of the gallery.
#
# 1. Invoke the AnchorSCAD render pipeline via its own devshell. We pin
#    to `nix develop -c` so the script picks up `openscad` + `assimp`
#    from `code/cad/flake.nix` even when run from `code/web/`'s shell.
# 2. Mirror every .glb the renderer produced into
#    `code/web/public/models/cad/`. We rsync rather than cp so reruns
#    don't duplicate files and Astro's static copy stays in sync with
#    the source of truth.
#
# Idempotent: safe to call repeatedly. Astro's `build` script chains
# this in front of `astro build` (see package.json).

set -euo pipefail

# Resolve to the web/ root regardless of cwd so this works from
# package.json scripts (which run with cwd = package dir) and from
# bare shells.
WEB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CAD_DIR="$(cd "$WEB_DIR/../cad" && pwd)"
PUBLIC_CAD_DIR="$WEB_DIR/public/models/cad"

mkdir -p "$PUBLIC_CAD_DIR"

echo "[prebuild-cad] rendering AnchorSCAD parts via $CAD_DIR/bin/render"
# TODO: tighten to `set -e` once cadeng has a stable release tag we can
# pin to. Today the cad flake follows `github:ncrmro/cadeng` HEAD, which
# trips GitHub's anonymous API rate limit on cold caches. Failing here
# would block the gallery build on transient 403s, so we degrade to a
# warning and let Astro render with whatever GLBs already exist on disk.
render_rc=0
(
  cd "$CAD_DIR"
  if command -v nix >/dev/null 2>&1; then
    nix develop -c ./bin/render
  else
    # CRITICAL: when invoked from CI that already has openscad+assimp on
    # PATH (e.g. inside the web flake's shell with cad tools layered in)
    # the nix-less fallback keeps the build working.
    ./bin/render
  fi
) || render_rc=$?
if [ "$render_rc" -ne 0 ]; then
  echo "[prebuild-cad] WARN: render exited $render_rc; continuing with existing build outputs" >&2
fi

BUILD_DIR="$CAD_DIR/build"
shopt -s nullglob
glbs=("$BUILD_DIR"/*.glb)
if [ ${#glbs[@]} -eq 0 ]; then
  echo "[prebuild-cad] WARN: no .glb files produced in $BUILD_DIR" >&2
  exit 0
fi

echo "[prebuild-cad] copying ${#glbs[@]} GLB(s) + .stl/.scad downloads -> $PUBLIC_CAD_DIR"
staged=()
for glb in "${glbs[@]}"; do
  base="$(basename "$glb" .glb)"
  cp -u "$glb" "$PUBLIC_CAD_DIR/"
  staged+=("$PUBLIC_CAD_DIR/${base}.glb")
  # Also stage source + STL so gallery cards can offer downloads:
  # .stl for slicers / printing, .scad to "Open in OpenSCAD" (the OS
  # opens the file in OpenSCAD when it's the default handler).
  for ext in stl scad; do
    src="$BUILD_DIR/${base}.${ext}"
    if [ -f "$src" ]; then
      cp -u "$src" "$PUBLIC_CAD_DIR/"
    fi
  done
done

# Bake an XYZ axis triad + ground grid into each staged GLB so the
# gallery cards have a SketchUp-style coordinate reference. add-axes
# is idempotent (removes prior bake markers before re-adding).
echo "[prebuild-cad] baking axes into ${#staged[@]} GLB(s)"
(cd "$CAD_DIR" && nix develop -c "$WEB_DIR/bin/add-axes" "${staged[@]}") \
  || echo "[prebuild-cad] WARN: add-axes failed; cards will render without axes" >&2

# Regenerate the gallery manifest from the staged GLB set — drop a new
# YAML into code/cad/specs/, run prebuild, and the manifest picks up
# the new substrate automatically. Non-fatal: a stale manifest still
# loads, just without the new entry.
echo "[prebuild-cad] regenerating gallery manifest"
(cd "$CAD_DIR" && nix develop -c "$WEB_DIR/bin/regen-manifest") \
  || echo "[prebuild-cad] WARN: regen-manifest failed; manifest unchanged" >&2

# Per-substrate routing reports (scoring + invariants + hole inventory)
# that the focus page renders. Writes to code/web/src/reports/*.json
# at build time so the .astro page can ?raw-import them with no
# request-time work. Non-fatal — the focus page falls back to "no
# routing report available" when a JSON is missing.
echo "[prebuild-cad] regenerating substrate reports"
(cd "$CAD_DIR" && nix develop -c "$CAD_DIR/bin/substrate-report") \
  || echo "[prebuild-cad] WARN: substrate-report failed; reports unchanged" >&2
