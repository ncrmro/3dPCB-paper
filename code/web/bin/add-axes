#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = [
#   "trimesh>=4.0",
#   "numpy>=2.0",
#   "scipy>=1.11",
#   "networkx>=3.0",
# ]
# ///
"""Bake an XYZ axis triad + ground grid into one or more GLB files.

`<model-viewer>` has no built-in axes / grid the way AnchorSCAD or
SketchUp does, so each gallery card needs the markers baked into
its own GLB. This script post-processes the files in place after
the cad / kicad render pipelines stage them.

Axis colours follow the glTF / SketchUp convention:
    X = red, Y = green, Z = blue.

Axis length and grid half-extent are sized per-model from each
GLB's bounding box, so a 13mm AnchorSCAD vitamin and an 80mm KiCad
PCB both get appropriately scaled markers.

Usage:
    add-axes path1.glb [path2.glb ...]
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

import numpy as np
import trimesh


def _axis_cylinder(direction: str, length: float, color_rgba: tuple) -> trimesh.Trimesh:
    """Coloured cylinder for one axis of the OpenSCAD-style gnomon.

    Direction labels follow OpenSCAD / AnchorSCAD convention:
        "x" → +X (right)   red
        "y" → -Z (back, away from default camera)   green
        "z" → +Y (up)   blue
    In OpenSCAD this is X-right / Y-back / Z-up; glTF's native frame
    is X-right / Y-up / Z-forward, so y and z swap visual meaning.
    """
    radius = length * 0.008
    cyl = trimesh.creation.cylinder(radius=radius, height=length, sections=12)
    # trimesh's cylinder() defaults to a height along +Z. Rotate each
    # axis to its OpenSCAD direction in glTF coords.
    rotations = {
        # +Z → +X
        "x": trimesh.transformations.rotation_matrix(np.pi / 2.0, [0.0, 1.0, 0.0]),
        # +Z → -Z (i.e. flip 180°)
        "y": trimesh.transformations.rotation_matrix(np.pi, [1.0, 0.0, 0.0]),
        # +Z → +Y
        "z": trimesh.transformations.rotation_matrix(-np.pi / 2.0, [1.0, 0.0, 0.0]),
    }
    axis_unit = {
        "x": [1.0, 0.0, 0.0],   # OpenSCAD X-right
        "y": [0.0, 0.0, -1.0],  # OpenSCAD Y-back
        "z": [0.0, 1.0, 0.0],   # OpenSCAD Z-up
    }[direction]
    cyl.apply_transform(rotations[direction])
    cyl.apply_translation(np.array(axis_unit) * (length / 2.0))
    cyl.visual.face_colors = np.tile(
        np.array(color_rgba, dtype=np.uint8), (len(cyl.faces), 1)
    )
    return cyl


def _ground_grid(extent: float, divisions: int = 20) -> trimesh.Trimesh:
    verts: list[tuple] = []
    faces: list[tuple] = []
    colors: list[tuple] = []
    step = (2 * extent) / divisions
    light = (220, 220, 220, 255)
    dark = (180, 180, 190, 255)
    for ix in range(divisions):
        for iz in range(divisions):
            x0 = -extent + ix * step
            z0 = -extent + iz * step
            x1 = x0 + step
            z1 = z0 + step
            base = len(verts)
            verts.extend(
                [
                    (x0, 0.0, z0),
                    (x1, 0.0, z0),
                    (x1, 0.0, z1),
                    (x0, 0.0, z1),
                ]
            )
            faces.extend([(base, base + 1, base + 2), (base, base + 2, base + 3)])
            c = light if (ix + iz) % 2 == 0 else dark
            colors.extend([c, c])
    return trimesh.Trimesh(
        vertices=np.array(verts, dtype=np.float32),
        faces=np.array(faces, dtype=np.int32),
        face_colors=np.array(colors, dtype=np.uint8),
        process=False,
    )


def _bake(path: Path, axis_scale: float, grid_y_offset: float, with_grid: bool) -> int:
    g = trimesh.load(str(path))
    if isinstance(g, trimesh.Scene):
        scene = g
    else:
        scene = trimesh.Scene()
        scene.add_geometry(g)

    # Drop any axis/grid nodes from a previous bake so reruns don't
    # stack duplicates. CRITICAL: trimesh's GLB export renames every
    # node to "geometry_N", so the original names from the prior bake
    # are gone — we identify stale markers by their uniform face color
    # instead. The RGB triples here MUST stay in sync with the colors
    # passed to add_geometry() below.
    _MARKER_RGB = {
        (220, 60, 60),    # axis_x
        (60, 200, 60),    # axis_y
        (60, 90, 220),    # axis_z
        (220, 220, 220),  # ground_grid light
        (180, 180, 190),  # ground_grid dark
    }
    for name in list(scene.geometry.keys()):
        if name in ("axis_x", "axis_y", "axis_z", "ground_grid"):
            scene.delete_geometry(name)
            continue
        mesh = scene.geometry[name]
        colors = getattr(mesh.visual, "face_colors", None)
        if colors is None or len(colors) == 0:
            continue
        unique = {tuple(c[:3]) for c in colors}
        if unique and unique.issubset(_MARKER_RGB):
            scene.delete_geometry(name)

    # Size axes from the model's bbox — works whether the GLB is in
    # metres (KiCad output) or millimetres (AnchorSCAD).
    bbox = scene.bounds
    extent = float(np.max(bbox[1] - bbox[0])) * axis_scale

    # Anchor the gnomon to the model's bottom-most-left corner (minX,
    # minY, minZ), NOT the glTF origin or the model centre. KiCad GLBs
    # live at world coords ~(0.14, 0, 0.085)m so axes at the glTF
    # origin would float far from the board; anchoring at the bbox
    # corner keeps the gnomon planted at the substrate's "0,0,0" corner
    # so the X/Y/Z arrows lay along the board edges instead of
    # bisecting the model.
    anchor = np.array(
        [
            float(bbox[0][0]),
            float(bbox[0][1]) + grid_y_offset,
            float(bbox[0][2]),
        ],
        dtype=np.float64,
    )

    def _at_anchor(mesh: trimesh.Trimesh) -> trimesh.Trimesh:
        mesh.apply_translation(anchor)
        return mesh

    scene.add_geometry(
        _at_anchor(_axis_cylinder("x", extent, (220, 60, 60, 255))),
        node_name="axis_x",
    )
    scene.add_geometry(
        _at_anchor(_axis_cylinder("y", extent, (60, 200, 60, 255))),
        node_name="axis_y",
    )
    scene.add_geometry(
        _at_anchor(_axis_cylinder("z", extent, (60, 90, 220, 255))),
        node_name="axis_z",
    )
    if with_grid:
        scene.add_geometry(
            _at_anchor(_ground_grid(extent=extent, divisions=20)),
            node_name="ground_grid",
        )

    scene.export(str(path))
    return path.stat().st_size


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("paths", nargs="+", type=Path)
    parser.add_argument(
        "--axis-scale",
        type=float,
        default=0.6,
        help="axis length as a fraction of the model's largest bbox dim "
        "(default: 0.6 = axes ~60%% of the model's longest edge)",
    )
    parser.add_argument(
        "--grid-y-offset",
        type=float,
        default=0.0,
        help="add this offset to the grid Y position (model units). "
        "Negative values push the grid below the model.",
    )
    # Off by default — the ground grid occludes the underside of the
    # model in <model-viewer>'s orbit controls. Axes alone give enough
    # coordinate reference; opt in with --grid when the floor is wanted.
    parser.add_argument(
        "--grid",
        dest="with_grid",
        action="store_true",
        default=False,
        help="also bake the ground grid (default: axes only)",
    )
    args = parser.parse_args()

    for p in args.paths:
        if not p.exists():
            print(f"skip {p}: not found", file=sys.stderr)
            continue
        size = _bake(
            p,
            axis_scale=args.axis_scale,
            grid_y_offset=args.grid_y_offset,
            with_grid=args.with_grid,
        )
        print(f"axes baked into {p} ({size:,} bytes)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
