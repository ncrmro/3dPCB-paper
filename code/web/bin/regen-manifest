#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = ["pyyaml>=6.0"]
# ///
"""Regenerate `code/web/src/manifest.cad.yaml` from the staged GLBs.

Walks `code/web/public/models/cad/*.glb`, classifies each by filename
pattern (vitamin / substrate / other), and writes a fresh manifest.
Idempotent — running it again with the same staged files produces the
same YAML. Invoked from `bin/prebuild-cad` after `add-axes`, so the
gallery picks up new substrates automatically: drop a YAML into
`code/cad/specs/`, run the prebuild, the new card appears.

Classification rules (pure filename heuristic — adjust here if a new
naming convention shows up):
- `*_breakout`, `*_supermini`     -> type: vitamin, camera: iso
- `*substrate*`, `*_coupon`,
  `substrate_*` (spec-generated)  -> camera: top
- everything else                 -> camera: iso (carriers, assemblies)
"""
from __future__ import annotations

import sys
from pathlib import Path

import yaml


WEB_DIR = Path(__file__).resolve().parent.parent
PUBLIC_CAD = WEB_DIR / "public" / "models" / "cad"
MANIFEST = WEB_DIR / "src" / "manifest.cad.yaml"

# Stable card order: vitamins first, then substrates, then everything else
# (carriers, assemblies). Within each group, sort alphabetically.
_VITAMIN_SUFFIXES = ("_breakout", "_supermini")
_SUBSTRATE_PATTERNS = ("substrate", "_coupon")


def _classify(stem: str) -> tuple[str, dict]:
    """Return (group, manifest_entry_extras) for sort + entry construction.
    Group is one of: 'vitamin', 'substrate', 'other'."""
    if any(stem.endswith(s) for s in _VITAMIN_SUFFIXES):
        return "vitamin", {"camera": "iso", "type": "vitamin"}
    if any(p in stem for p in _SUBSTRATE_PATTERNS):
        return "substrate", {"camera": "top"}
    return "other", {"camera": "iso"}


_GROUP_ORDER = {"vitamin": 0, "substrate": 1, "other": 2}


def main() -> int:
    if not PUBLIC_CAD.is_dir():
        print(f"regen-manifest: {PUBLIC_CAD} not found", file=sys.stderr)
        return 1
    glbs = sorted(PUBLIC_CAD.glob("*.glb"))
    if not glbs:
        print(f"regen-manifest: no GLBs under {PUBLIC_CAD}", file=sys.stderr)
        return 0

    entries: list[tuple[int, str, dict]] = []
    for glb in glbs:
        stem = glb.stem
        group, extras = _classify(stem)
        entry = {
            "name": stem,
            "glb": f"/models/cad/{glb.name}",
            **extras,
        }
        entries.append((_GROUP_ORDER[group], stem, entry))
    entries.sort()
    models = [e[2] for e in entries]

    manifest = {
        "project": "cad",
        "cameras": {
            "iso":   "55deg 75deg 200mm",
            "front": "0deg 90deg 200mm",
            "top":   "0deg 0deg 200mm",
        },
        "models": models,
    }

    # Preserve the file header — it's helpful for humans reading the
    # checked-in YAML. yaml.safe_dump() loses comments by design.
    header = (
        "# Gallery manifest for AnchorSCAD outputs — AUTO-GENERATED by\n"
        "# code/web/bin/regen-manifest from public/models/cad/*.glb.\n"
        "# Edit the GLB set (drop a YAML into code/cad/specs/, run\n"
        "# bin/prebuild) — DON'T hand-edit this file; it'll be overwritten.\n"
        "#\n"
        "# `type: vitamin` flags AnchorSCAD-built approximations of off-the-\n"
        "# shelf parts; the gallery partitions these into their own section.\n\n"
    )
    body = yaml.safe_dump(manifest, sort_keys=False, default_flow_style=False)
    MANIFEST.write_text(header + body)
    print(f"regen-manifest: wrote {len(models)} entries to {MANIFEST}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
