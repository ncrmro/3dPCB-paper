# Bambu LAN bridge — printer credentials. Copy to `.env` and fill in;
# `.env` is gitignored. Loaded by process-compose's `dotenv:` for the
# bambu-bridge process only.

BAMBU_IP=192.168.1.121
BAMBU_SERIAL=22E…
# 8-char LAN access code from the printer's Settings → General → LAN Mode.
BAMBU_ACCESS_CODE=

# Optional: override which build plate the slicer assumes. Must match
# the plate physically installed; mismatch makes the printer refuse the
# job (PAUSE in stage 11, build-plate error). P2S default plate = 4
# = "Textured PEI Plate". Other common values: "Bambu Cool Plate",
# "Bambu Engineering Plate", "Bambu High Temperature Plate",
# "Bambu Supertack Plate". Default if unset: "Textured PEI Plate".
#BAMBU_BED_TYPE="Textured PEI Plate"
