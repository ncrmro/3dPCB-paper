# KiCad per-user GUI/state cache — regenerated by kicad-cli and the GUI.
# WHY: .kicad_prl encodes the active layer, viewport, selection filters,
# etc. for the local user; committing it forces every contributor to
# re-fight someone else's window state.
*.kicad_prl

# Local fp-info-cache / sym-lib-table autosaves.
fp-info-cache

# KiCad per-session lock files (e.g. ~spike.kicad_pro.lck).
*.lck
