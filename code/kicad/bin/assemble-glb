#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = [
#   "trimesh>=4.0",
#   "numpy>=2.0",
#   "lxml>=5.0",
#   "networkx>=3.0",
#   "scipy>=1.11",
# ]
# ///
"""Merge code/kicad/build/spike.glb with the AnchorSCAD vitamin GLBs.

`kicad-cli pcb export glb` honours `(model ...)` refs only when they
point at STEP files. We compose at a higher level instead: the bare
KiCad PCB exports as one GLB (board + tracks + silkscreen + …); each
AnchorSCAD vitamin exports as its own GLB; this script positions the
vitamin meshes above the corresponding KiCad footprints and merges
the lot into a single assembled GLB.

The result is what shows up in code/web/public/models/kicad/spike.glb
— the full embodiment: PCB + tracks + headers' worth of breakout
modules on top.
"""
from __future__ import annotations

import argparse
from pathlib import Path

import numpy as np
import trimesh


# ----- KiCad → GLB coordinate transform --------------------------------
# kicad-cli writes the GLB in meters, glTF Y-up. The PCB's KiCad-space
# coordinates (mm, Y-down page) map to GLB coords as:
#   x_glb = x_kicad / 1000
#   y_glb = z_kicad / 1000      (KiCad Z-up becomes glTF Y-up)
#   z_glb = y_kicad / 1000      (KiCad Y down-page maps to glTF +Z)
#
# AnchorSCAD vitamins are authored mm, Z-up. To place one at a KiCad
# footprint (fx, fy) we:
#   1. Scale by 1/1000 (mm → m).
#   2. Rotate 90° around glTF +X so the vitamin's Z-up axis lines up
#      with glTF Y-up. After this rotation the vitamin's Y now points
#      in glTF -Z; we re-flip via a 180° Y rotation if needed.
#   3. Translate to (fx/1000, board_top_y, fy/1000).
#
# board_top_y = (kicad-cli centres the PCB body around y=0 in the GLB;
# top of board is at +half_thickness ≈ 0.0008m). We over-lift by the
# header height so the breakout sits above the pins, not in them.

MM_TO_M = 1.0 / 1000.0
BOARD_TOP_Y_M = 0.0008  # half of 1.6mm board thickness
HEADER_HEIGHT_M = 8.5 * MM_TO_M  # 8.5mm female-header body height


def kicad_to_glb(fx_mm: float, fy_mm: float, extra_z_mm: float = 0.0) -> np.ndarray:
    """Return the (x, y, z) translation in GLB metres for a KiCad footprint."""
    return np.array(
        [
            fx_mm * MM_TO_M,
            BOARD_TOP_Y_M + HEADER_HEIGHT_M + extra_z_mm * MM_TO_M,
            fy_mm * MM_TO_M,
        ]
    )


def anchorscad_orient() -> np.ndarray:
    """4x4 transform aligning AnchorSCAD's Z-up to glTF's Y-up.

    The vitamins are authored with the breakout PCB's underside (pins)
    at -Z and the sensor face / component side at +Z. We want pins
    pointing DOWN into the board's headers in glTF, i.e. -Y. That's a
    -90° rotation around +X: (x, y, z) → (x, z, -y). The earlier
    +90° put pins at +Y, which is why every module appeared flipped.
    """
    return trimesh.transformations.rotation_matrix(-np.pi / 2.0, [1.0, 0.0, 0.0])


def yaw_matrix(deg: float) -> np.ndarray:
    """Rotation around the AnchorSCAD module's own Z (vertical) axis.

    Applied in the module's native frame BEFORE `anchorscad_orient`,
    so the sense matches "spin the breakout PCB around its centre on
    the workbench". Positive degrees = counter-clockwise looking down
    the +Z axis (right-hand rule).
    """
    return trimesh.transformations.rotation_matrix(
        np.radians(deg), [0.0, 0.0, 1.0]
    )


def scale_matrix(s: float) -> np.ndarray:
    m = np.eye(4)
    m[0, 0] = m[1, 1] = m[2, 2] = s
    return m


def translate_matrix(v: np.ndarray) -> np.ndarray:
    m = np.eye(4)
    m[:3, 3] = v
    return m


# Placements: which AnchorSCAD GLB sits over which KiCad footprint.
# Coordinates match gen_spike_pcb.py's footprint positions; the
# Supermini straddles J1A + J1B so we centre it between them.
ORIGIN_X = 100.0  # gen_spike_pcb.py ORIGIN_X
ORIGIN_Y = 60.0   # gen_spike_pcb.py ORIGIN_Y
PITCH = 2.54

J1A_X = ORIGIN_X + 10.0
J1B_X = J1A_X + 17.78
J2_X = ORIGIN_X + 45.0
J3_X = ORIGIN_X + 60.0
HEADERS_Y = ORIGIN_Y + 8.0

PLACEMENTS = [
    # ref, GLB name, kicad x_mm (pin1), kicad y_mm (pin1), pin_count,
    # yaw_deg (around vitamin Z), pin_row_local_y_mm.
    #
    # `pin_row_local_y_mm` is the Y coord of the pin-row centroid in
    # the *vitamin's* local frame (in mm). The vitamin's origin is at
    # the PCB centre but the through-hole header lives along an edge.
    # For SCD41 / BH1750 the header is on -Y (header_y = -depth/2 +
    # header_body_width/2 in sensors.py). Without compensating for
    # that offset, the vitamin lands ~9mm west of the KiCad header
    # because the assembler placed the vitamin *centre* at the KiCad
    # pin-row centre instead of the *pin row* at it.
    #
    # Sensors yaw -90° so their +Y pin axis aligns with KiCad +X after
    # the 270° KiCad footprint rotation. Supermini is symmetric
    # across its two-row header block; yaw 0, offset 0.
    ("ESP32", "esp32_c3_supermini", (J1A_X + J1B_X) / 2.0, HEADERS_Y, 9,  0.0,  0.0),
    ("SCD41", "scd41_breakout",      J2_X,                HEADERS_Y, 4, -90.0, -9.605),
    ("BH1750", "bh1750_breakout",    J3_X,                HEADERS_Y, 5, -90.0, -7.980),
]


def _load_scene(path: Path) -> trimesh.Scene:
    """Load a GLB as a Scene preserving its per-mesh materials."""
    g = trimesh.load(str(path))
    if isinstance(g, trimesh.Scene):
        return g
    s = trimesh.Scene()
    s.add_geometry(g)
    return s


def _axis_cylinder(direction: str, length_m: float, color_rgba: tuple) -> trimesh.Trimesh:
    """Coloured cylinder along ±X / ±Y / ±Z for an axis marker."""
    radius = length_m * 0.008  # thin but visible
    cyl = trimesh.creation.cylinder(radius=radius, height=length_m, sections=12)
    # Cylinder defaults to +Z; rotate to the requested axis, then
    # translate so it grows from the origin (not centred at origin).
    rotations = {
        "x": trimesh.transformations.rotation_matrix(np.pi / 2.0, [0.0, 1.0, 0.0]),
        "y": trimesh.transformations.rotation_matrix(-np.pi / 2.0, [1.0, 0.0, 0.0]),
        "z": np.eye(4),
    }
    axis_unit = {"x": [1, 0, 0], "y": [0, 1, 0], "z": [0, 0, 1]}[direction]
    cyl.apply_transform(rotations[direction])
    cyl.apply_translation(np.array(axis_unit) * (length_m / 2.0))
    cyl.visual.face_colors = np.tile(np.array(color_rgba, dtype=np.uint8), (len(cyl.faces), 1))
    return cyl


def _ground_grid(extent_m: float, divisions: int = 20) -> trimesh.Trimesh:
    """Flat checkered plane at glTF y=0 — alternating light/dark squares."""
    verts: list[tuple] = []
    faces: list[tuple] = []
    colors: list[tuple] = []
    step = (2 * extent_m) / divisions
    light = (220, 220, 220, 255)
    dark = (180, 180, 190, 255)
    for ix in range(divisions):
        for iz in range(divisions):
            x0 = -extent_m + ix * step
            z0 = -extent_m + iz * step
            x1 = x0 + step
            z1 = z0 + step
            base = len(verts)
            verts.extend(
                [
                    (x0, 0.0, z0),
                    (x1, 0.0, z0),
                    (x1, 0.0, z1),
                    (x0, 0.0, z1),
                ]
            )
            faces.extend([(base, base + 1, base + 2), (base, base + 2, base + 3)])
            c = light if (ix + iz) % 2 == 0 else dark
            colors.extend([c, c])
    return trimesh.Trimesh(
        vertices=np.array(verts, dtype=np.float32),
        faces=np.array(faces, dtype=np.int32),
        face_colors=np.array(colors, dtype=np.uint8),
        process=False,
    )


def add_axes_and_grid(scene: trimesh.Scene, axis_len_m: float) -> None:
    """Attach an XYZ axis triad at origin and a checkered ground grid.

    Colours follow the SketchUp / glTF convention: X = red, Y = green,
    Z = blue. The grid sits at y=0 (the plane the PCB rests on after
    `HEADER_HEIGHT_M`) and extends `axis_len_m` in each X/Z direction.
    """
    scene.add_geometry(
        _axis_cylinder("x", axis_len_m, (220, 60, 60, 255)),
        node_name="axis_x",
    )
    scene.add_geometry(
        _axis_cylinder("y", axis_len_m, (60, 200, 60, 255)),
        node_name="axis_y",
    )
    scene.add_geometry(
        _axis_cylinder("z", axis_len_m, (60, 90, 220, 255)),
        node_name="axis_z",
    )
    scene.add_geometry(
        _ground_grid(extent_m=axis_len_m, divisions=20),
        node_name="ground_grid",
    )


def main() -> int:
    here = Path(__file__).resolve().parent
    kicad_dir = here.parent
    cad_build = kicad_dir.parent / "cad" / "build"

    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--pcb-glb",
        default=str(kicad_dir / "build" / "spike.glb"),
        help="bare PCB GLB exported by kicad-cli (default: build/spike.glb)",
    )
    parser.add_argument(
        "--cad-build",
        default=str(cad_build),
        help="directory of AnchorSCAD GLBs (default: ../cad/build)",
    )
    parser.add_argument(
        "--output",
        default=str(kicad_dir / "build" / "spike-assembly.glb"),
        help="merged GLB (default: build/spike-assembly.glb — keeps "
        "the bare spike.glb intact so consumers can show both views)",
    )
    parser.add_argument(
        "--axes",
        dest="axes",
        action="store_true",
        default=True,
        help="bake an XYZ axis triad + ground grid into the output "
        "(default; pass --no-axes to disable)",
    )
    parser.add_argument(
        "--no-axes",
        dest="axes",
        action="store_false",
    )
    parser.add_argument(
        "--axes-extent-m",
        type=float,
        default=0.12,
        help="axis length and grid half-extent in metres (default: "
        "0.12, ~12cm, matches the spike PCB scale)",
    )
    args = parser.parse_args()

    pcb_path = Path(args.pcb_glb)
    cad_build_dir = Path(args.cad_build)
    out_path = Path(args.output)

    if not pcb_path.exists():
        print(f"error: PCB GLB not found: {pcb_path}")
        return 1

    # Start from the PCB scene and add each vitamin as its own
    # geometry node with its own transform. Scene preserves per-mesh
    # materials through GLB export — concat would flatten the
    # PBR / vertex-color metadata kicad-cli wrote into the PCB GLB.
    scene = _load_scene(pcb_path)
    print(f"loaded PCB: {len(scene.geometry)} mesh(es), bbox {scene.bounds.tolist()}")

    orient = anchorscad_orient()
    scale = scale_matrix(MM_TO_M)

    for ref, name, fx, fy, pin_count, yaw_deg, pin_row_local_y in PLACEMENTS:
        glb_path = cad_build_dir / f"{name}.glb"
        if not glb_path.exists():
            print(f"  skip {ref} ({name}): {glb_path} not found")
            continue
        vitamin = _load_scene(glb_path)

        # Step 1: compute target — the centroid of the rotated KiCad
        # pin row in world coords. KiCad footprint angle equals the
        # vitamin yaw (both CCW around the local up-axis; the orient
        # transform identifies AnchorSCAD +Z with KiCad +Z = glTF +Y).
        # Pad column local goes pin1 (0,0) → pinN (0, span); after a
        # CCW rot θ this becomes world (-span·sinθ, +span·cosθ).
        half_span = ((pin_count - 1) * PITCH) / 2.0
        theta = np.radians(yaw_deg)
        target_cx_mm = fx - half_span * np.sin(theta)
        target_cy_mm = fy + half_span * np.cos(theta)

        # Step 2: compensate for pin-row offset in vitamin's frame.
        # The vitamin origin is at PCB centre; the pin-row centroid
        # is at local (0, pin_row_local_y, 0). After yaw + orient
        # this offset shows up in glTF as (-sinθ·py, 0, -cosθ·py).
        # Subtract that from the translation so the *pin row*, not
        # the vitamin centre, ends up at the KiCad target.
        glb_off_x_mm = -np.sin(theta) * pin_row_local_y
        glb_off_z_mm = -np.cos(theta) * pin_row_local_y
        adjusted_cx_mm = target_cx_mm - glb_off_x_mm
        adjusted_cy_mm = target_cy_mm - glb_off_z_mm
        translation = kicad_to_glb(adjusted_cx_mm, adjusted_cy_mm)

        # Step 3: compose transform. Order with @: yaw applies first
        # (vitamin frame), then scale (mm → m), then orient (Z→Y),
        # then translate (target placement in glTF metres).
        node_transform = (
            translate_matrix(translation) @ orient @ scale @ yaw_matrix(yaw_deg)
        )
        for geom_name, geom in vitamin.geometry.items():
            scene.add_geometry(
                geom,
                node_name=f"{ref}__{geom_name}",
                transform=node_transform,
            )
        print(f"  placed {ref} ({name}) yaw={yaw_deg}° at glb {translation.tolist()}")

    if args.axes:
        add_axes_and_grid(scene, axis_len_m=args.axes_extent_m)
        print(f"  added XYZ axes + ground grid (extent {args.axes_extent_m}m)")

    scene.export(str(out_path))
    print(f"wrote {out_path} ({out_path.stat().st_size:,} bytes)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
