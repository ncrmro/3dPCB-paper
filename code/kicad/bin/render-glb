#!/usr/bin/env bash
# render-glb — export a .kicad_pcb to GLB via kicad-cli.
#
# Usage: render-glb PATH/TO/board.kicad_pcb [OUTPUT_DIR]
#
# Defaults OUTPUT_DIR to code/kicad/build/ relative to this script.
# The GLB feeds <model-viewer> in the planned gallery (see
# docs/plants/W20-demoable-paper.md).

set -euo pipefail

if [[ $# -lt 1 || $# -gt 2 ]]; then
  echo "usage: $(basename "$0") PATH/TO/board.kicad_pcb [OUTPUT_DIR]" >&2
  exit 2
fi

pcb="$1"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
default_out="${script_dir}/../build"
out_dir="${2:-$default_out}"

if [[ ! -f "$pcb" ]]; then
  echo "error: input not found: $pcb" >&2
  exit 1
fi

mkdir -p "$out_dir"

base="$(basename "$pcb" .kicad_pcb)"
out="${out_dir}/${base}.glb"

# `kicad-cli pcb export glb` defaults to board body + 3D component
# meshes only — no copper, no silk, no soldermask. The result looks
# like a bare green slab. Include the full stackup so the GLB
# matches what `kicad-cli pcb render` raytraces into the iso PNG:
# tracks, pads, zones (copper pours), silkscreen, and soldermask
# (green tint where there's no copper). `--fuse-shapes` coalesces
# overlapping geometry to keep the GLB small.
kicad-cli pcb export glb "$pcb" -o "$out" \
  --include-tracks \
  --include-pads \
  --include-zones \
  --include-silkscreen \
  --include-soldermask \
  --fuse-shapes \
  --force

echo "done: ${out}"
