# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# uv
.uv-cache/

# Build outputs
cad/build/
build/
*.stl

# Keep the kicad build/ directory tracked (for prebuild scripts) but
# ignore its generated contents. The negation must follow the broader
# build/ rule above.
!code/kicad/build/
code/kicad/build/*
!code/kicad/build/.gitkeep

# Bun workspace artefacts (workspace root hoists deps to code/)
code/node_modules/
code/bun.lock
code/bun.lockb

# Astro build artefacts
code/web/dist/
code/web/.astro/

# Nix / direnv
.direnv/
.envrc.local

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
